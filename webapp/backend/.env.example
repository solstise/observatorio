# Carpeta raiz del repo observatorio. Se usa para resolver data/outputs/.
# Por defecto se calcula como ../../ respecto al backend.
DATA_ROOT=

# Orígenes permitidos por CORS, separados por coma.
# Ejemplo: http://localhost:3000,https://observatorio-posadas.ar
ALLOWED_ORIGINS=http://localhost:3000

# API key para uso autenticado (rate limit mayor). Opcional.
# Si no se define, la API es solo publica con rate limit bajo.
API_KEY=

# Rate limits (por IP). Formato slowapi.
RATE_LIMIT_PUBLIC=100/minute
RATE_LIMIT_AUTHED=600/minute

# Redis opcional para rate limiting distribuido.
# Si no se define, slowapi usa memoria local.
REDIS_URL=

# Version visible en /api/version.
APP_VERSION=0.1.0-fase3
