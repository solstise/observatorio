# URL base del backend FastAPI. Si se deja vacio, el frontend
# consume solo archivos estaticos de /public/data.
# Ejemplo local: http://localhost:8000
# Ejemplo prod: https://api.observatorio-posadas.ar
NEXT_PUBLIC_API_BASE=

# Version publicada (se muestra en footer). Si no se define,
# se usa el valor de src/lib/version.ts.
NEXT_PUBLIC_VERSION=

# Fecha de ultima actualizacion de datos (ISO). Si no se define,
# se toma del archivo /public/data/updated_at.txt.
NEXT_PUBLIC_UPDATED_AT=
