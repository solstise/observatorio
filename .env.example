# ============================================================================
# Observatorio Urbano Posadas - Variables de entorno
# ============================================================================
# Copiá este archivo a .env y completá los valores reales.
# NO commitees .env al repositorio (ya está en .gitignore).
# ----------------------------------------------------------------------------

# ---- Google Earth Engine (obligatorio Fase 1) ----
# ID del proyecto de Google Cloud con Earth Engine API habilitada.
# Obtenelo de https://console.cloud.google.com/ > proyecto > "ID del proyecto".
EE_PROJECT_ID=tu-proyecto-gcp-aqui

# Ruta al JSON de service account (opcional). Si usás `earthengine authenticate`
# con cuenta personal dejá esto vacío. Solo se usa en automatizaciones (Fase 2).
EE_SERVICE_ACCOUNT_FILE=

# ---- Planet NICFI (Fase 2) ----
# API key obtenida del formulario NICFI (https://www.planet.com/nicfi/).
# El formulario se aprueba en 24-72 hs. Para Fase 1 podés dejarlo vacío.
PLANET_API_KEY=

# ---- Google Maps / Geocoding (opcional) ----
# Solo para validación cualitativa en notebooks. El pipeline funciona sin esto.
GOOGLE_MAPS_API_KEY=

# ---- Notificaciones (Fase 2, pipeline mensual) ----
# Webhook de Slack para notificar éxito/fallo de la corrida mensual.
SLACK_WEBHOOK_URL=

# Alternativa por Telegram.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Paths ----
# Dónde se guardan los outputs finales (PDFs, timelapses).
OUTPUT_DIR=./data/outputs

# Dónde se cachean los descargables raw (GeoTIFF, GeoJSON, shapefiles).
CACHE_DIR=./data/raw

# ---- Webapp (Fase 3) ----
# Credenciales de basic auth para la preview interna del ministerio.
WEBAPP_BASIC_AUTH_USER=
WEBAPP_BASIC_AUTH_PASS=

# URL pública del sitio (para OpenGraph, canonical tags).
PUBLIC_SITE_URL=https://observatorioposadas.org

# ---- Base de datos (Fase 3, opcional) ----
# Connection string PostgreSQL+PostGIS si se migra del stack estático a API.
# Ejemplo: postgresql://usuario:password@host:5432/observatorio
# POSTGRES_URL=

# ---- Observabilidad (opcional) ----
# DSN de Sentry para capturar errores runtime.
# SENTRY_DSN=
